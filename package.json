{
  "name": "daily-record-firebase-tests",
  "private": true,
  "type": "module",
  "scripts": {
    "test:android-connected": "firebase emulators:exec --project demo-daily-record-app --only auth,firestore \"gradlew.bat connectedDebugAndroidTest --no-parallel\"",
